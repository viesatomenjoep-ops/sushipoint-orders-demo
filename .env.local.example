NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side only. Never prefix with NEXT_PUBLIC_ and never import this in
# client components — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret n8n must send as the `x-webhook-secret` header when POSTing
# to /api/orders. Generate a long random value, e.g. `openssl rand -hex 32`.
N8N_ORDERS_WEBHOOK_SECRET=

# Vapi public API key (Vapi dashboard → Settings → API Keys → Public Key).
# Safe to expose client-side — powers the floating voice widget.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
